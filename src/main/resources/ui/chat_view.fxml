<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.graden.models.controller.ChatController">
    <children>
        <BorderPane>
           <center>
              <!-- VBox wrapper to stack Chat Area (Top) and Input Area (Bottom) in the Center Column -->
              <VBox spacing="0" minHeight="0.0"> 
                  <children>
                      <javafx.scene.layout.StackPane VBox.vgrow="ALWAYS" styleClass="stack-pane-content" minHeight="0.0">
                         <children>
                             <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="chat-scroll-pane" minHeight="0.0">
                                 <content>
                                    <VBox fx:id="messagesContainer" spacing="15.0" styleClass="chat-area" minHeight="0.0">
                                       <padding>
                                          <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                       </padding>
                                    </VBox>
                                 </content>
                             </ScrollPane>
                             
                             <!-- Welcome Container for New Chats -->
                             <VBox fx:id="welcomeContainer" alignment="CENTER" spacing="40.0" visible="false">
                                <children>
                                    <Label fx:id="welcomeLabel" text="" styleClass="welcome-label" style="-fx-font-size: 36px; -fx-font-weight: 300; -fx-text-fill: -color-fg-default;"/> <!-- Text set by animation -->
                                    
                                    <!-- Step 1: Model Selection Setup -->
                                    <VBox fx:id="setupContainer" alignment="CENTER" spacing="20.0">
                                        <javafx.scene.control.ComboBox fx:id="initialModelSelector" promptText="%chat.selectModel" 
                                                                     styleClass="big-combo-box" prefWidth="350.0" onAction="#onInitialModelSelected"/>
                                    </VBox>
                                    
                                    <!-- Input Capsule will be injected here dynamically, but HIDDEN initially -->
                                </children>
                             </VBox>
                         </children>
                      </javafx.scene.layout.StackPane>
                                            <!-- Input Container (Fixed in the Center Column) -->
                       <VBox fx:id="bottomInputContainer" styleClass="input-container-wrapper" alignment="BOTTOM_CENTER" VBox.vgrow="NEVER">
                 <children>

                    <!-- Floating Input Card (Big VBox) — RAG chips are INSIDE -->
                    <VBox fx:id="inputCapsule" styleClass="input-card" maxWidth="800.0" spacing="10.0">
                       <children>
                       <!-- RAG Chips (always part of the input card) -->
                       <HBox fx:id="ragChipsContainer" alignment="CENTER" spacing="6.0" visible="true" managed="true" styleClass="rag-chips-floating" maxWidth="800.0">
                           <padding>
                               <Insets bottom="2.0" left="4.0" right="4.0" top="4.0"/>
                           </padding>
                       </HBox>
                       <!-- Top Row: Input Text -->
                          <TextArea fx:id="inputField" maxHeight="200.0" minHeight="50.0" prefHeight="50.0" prefRowCount="2" 
                                    promptText="%chat.inputPrompt" wrapText="true" VBox.vgrow="ALWAYS" styleClass="transparent-area"/>
                          
                          <!-- Bottom Row: Tools & Actions -->
                          <HBox fx:id="inputToolbarRow" alignment="CENTER_LEFT" spacing="15.0">
                              <children>
                                  <Button fx:id="attachButton" onAction="#onAttachClicked" styleClass="attach-button-icon">
                                      <graphic>
                                          <FontIcon iconLiteral="fth-paperclip" iconSize="16" styleClass="font-icon" />
                                      </graphic>
                                      <tooltip>
                                          <javafx.scene.control.Tooltip text="%chat.attachTooltip" />
                                      </tooltip>
                                  </Button>

                                  <Button fx:id="exportMdButton" onAction="#onExportMdClicked" styleClass="attach-button-icon">
                                      <graphic>
                                          <FontIcon iconLiteral="fth-download" iconSize="16" styleClass="font-icon" />
                                      </graphic>
                                      <tooltip>
                                          <javafx.scene.control.Tooltip text="%chat.exportTooltip" />
                                      </tooltip>
                                  </Button>



                                  <Region HBox.hgrow="ALWAYS" />

                                  <javafx.scene.control.ComboBox fx:id="modelSelector" promptText="%chat.selectModel" styleClass="capsule-combo-box" prefWidth="150.0" />
                                  
                                  <!-- Sidebar Toggle Removed from Here -->
                                  <javafx.scene.layout.StackPane alignment="CENTER_RIGHT">
                                      <Button fx:id="sendButton" onAction="#sendMessage" styleClass="send-button-icon">
                                          <graphic>
                                              <FontIcon iconLiteral="fth-send" iconSize="16" styleClass="font-icon" />
                                          </graphic>
                                          <tooltip>
                                              <javafx.scene.control.Tooltip text="%chat.sendHint" />
                                          </tooltip>
                                      </Button>
                                      <Button fx:id="cancelButton" onAction="#onCancelClicked" styleClass="send-button-icon" visible="false" managed="false" style="-fx-background-color: #ff4444;">
                                          <graphic>
                                              <FontIcon iconLiteral="fth-square" iconSize="16" styleClass="font-icon" />
                                          </graphic>
                                      </Button>
                                  </javafx.scene.layout.StackPane>
                              </children>
                          </HBox>
                       </children>
                       <padding>
                          <Insets bottom="15.0" left="20.0" right="15.0" top="15.0" />
                       </padding>
                    </VBox>
                 </children>
                 <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
                 </padding>
              </VBox>
          </children>
       </VBox>
    </center>
    <right>
                <VBox fx:id="rightSidebar" prefWidth="280.0" styleClass="chat-sidebar-right" BorderPane.alignment="CENTER">
                    <children>
                        <!-- Scrollable so no section (incl. System Instructions) is ever clipped. -->
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                          <content>
                            <VBox spacing="25" styleClass="sidebar-card">
                                <padding>
                                    <Insets top="20.0" right="15.0" bottom="20.0" left="15.0"/>
                                </padding>
                                <children>
                            <!-- PRESETS -->
                            <VBox spacing="2">
                                <Label text="%chat.presets" styleClass="sidebar-section-label" />
                                <ComboBox fx:id="presetSelector" promptText="Select Preset" maxWidth="Infinity" styleClass="sidebar-combo-box" />
                            </VBox>

                            <!-- CREATIVITY (Temperature) -->
                            <VBox spacing="5">
                                <VBox spacing="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="%chat.creativity" styleClass="sidebar-section-label" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="tempValueLabel" text="%chat.creativity.balanced" styleClass="sidebar-value-label" />
                                    </HBox>
                                    <Label text="%chat.creativity.desc" styleClass="sidebar-description-label" wrapText="true" maxWidth="200"/>
                                </VBox>
                                <Slider fx:id="tempSlider" min="0" max="1" value="0.7" blockIncrement="0.1" majorTickUnit="0.5" minorTickCount="4" showTickMarks="true" showTickLabels="true" />
                            </VBox>

                            <!-- CONTEXT WINDOW -->
                            <VBox spacing="5">
                                <VBox spacing="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="%chat.context" styleClass="sidebar-section-label" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="ctxValueLabel" text="4096" styleClass="sidebar-value-label" />
                                    </HBox>
                                    <Label text="%chat.context.desc" styleClass="sidebar-description-label" wrapText="true" maxWidth="200"/>
                                </VBox>
                                <Slider fx:id="ctxSlider" min="2048" max="32768" value="4096" blockIncrement="1024" snapToTicks="true" majorTickUnit="16384" minorTickCount="4" showTickMarks="true" showTickLabels="true" />
                            </VBox>

                            <!-- Top-K -->
                            <VBox spacing="5">
                                <VBox spacing="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="Top-K" styleClass="sidebar-section-label" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="topKValueLabel" text="40" styleClass="sidebar-value-label" />
                                    </HBox>
                                    <Label text="%chat.topk.desc" styleClass="sidebar-description-label" wrapText="true" maxWidth="200" minHeight="-Infinity"/>
                                </VBox>
                                <Slider fx:id="topKSlider" min="1" max="100" value="40" blockIncrement="1" majorTickUnit="20" minorTickCount="4" showTickMarks="true" showTickLabels="true" snapToTicks="true" />
                            </VBox>

                            <!-- Top-P -->
                            <VBox spacing="5">
                                <VBox spacing="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="Top-P" styleClass="sidebar-section-label" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="topPValueLabel" text="0.9" styleClass="sidebar-value-label" />
                                    </HBox>
                                    <Label text="%chat.topp.desc" styleClass="sidebar-description-label" wrapText="true" maxWidth="200" minHeight="-Infinity"/>
                                </VBox>
                                <Slider fx:id="topPSlider" min="0.0" max="1.0" value="0.9" blockIncrement="0.1" majorTickUnit="0.5" minorTickCount="4" showTickMarks="true" showTickLabels="true" />
                            </VBox>

                            <!-- SEED -->
                            <VBox spacing="5">
                                <VBox spacing="2">
                                    <Label text="%chat.seed" styleClass="sidebar-section-label" />
                                    <Label text="%chat.seed.desc" styleClass="sidebar-description-label" wrapText="true" maxWidth="200"/>
                                </VBox>
                                <TextField fx:id="seedField" promptText="Random (-1)" styleClass="sidebar-text-field" />
                            </VBox>

                            <!-- TOOLS -->
                            <VBox spacing="4">
                                <VBox spacing="2">
                                    <Label text="%chat.tools" styleClass="sidebar-section-label" />
                                    <Label text="%chat.tools.desc" styleClass="sidebar-description-label" wrapText="true" maxWidth="200"/>
                                </VBox>
                                <CheckBox fx:id="toolsToggle" text="%chat.tools.enable" styleClass="sidebar-checkbox" />
                            </VBox>

                            <!-- JSON MODE -->
                            <VBox spacing="4">
                                <CheckBox fx:id="jsonModeToggle" text="%chat.jsonMode.label" styleClass="sidebar-checkbox" />
                                <TextField fx:id="jsonSchemaField" promptText="%chat.jsonMode.schemaHint" styleClass="sidebar-text-field" visible="false" managed="false" />
                            </VBox>

                            <!-- SYSTEM PROMPT -->
                            <VBox spacing="5">
                                <Label text="%chat.systemInstructions" styleClass="sidebar-section-label" />
                                <TextArea fx:id="systemPromptField" wrapText="true" styleClass="sidebar-text-area" promptText="You are a helpful assistant..." prefRowCount="6" />
                            </VBox>
                                </children>
                            </VBox>
                          </content>
                        </ScrollPane>
                    </children>
                </VBox>
    </right>
           <!-- Bottom Removed (Input moved to Center) -->
        </BorderPane>
        
        <!-- Floating Action Button for Sidebar Toggle -->
        <Button fx:id="sidebarToggleButton" onAction="#toggleSidebar" styleClass="floating-settings-button" text="⚙" StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets bottom="30.0" right="30.0"/>
            </StackPane.margin>
            <tooltip>
                <javafx.scene.control.Tooltip text="%chat.toggleSidebar" />
            </tooltip>
        </Button>
    </children>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.graden.models.controller.ModelDetailController"
      styleClass="edge-to-edge, detail-root" spacing="18.0">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <!-- Top Header: Name + Command Box -->
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label fx:id="modelNameLabel" text="Model Name" styleClass="detail-title"
                       HBox.hgrow="ALWAYS" maxWidth="Infinity" wrapText="true" />

                <Region HBox.hgrow="ALWAYS" />

                <HBox fx:id="commandBox" alignment="CENTER_LEFT" spacing="10.0" styleClass="command-box">
                    <padding>
                        <Insets bottom="6.0" left="10.0" right="10.0" top="6.0" />
                    </padding>
                    <children>
                        <Label fx:id="commandLabel" styleClass="command-text" text="ollama run model" />
                        <Button fx:id="copyButton" styleClass="icon-button, copy-button">
                            <graphic>
                                <Region styleClass="icon-region, icon-copy" />
                            </graphic>
                            <tooltip>
                                <Tooltip text="%detail.command.copy.tooltip" />
                            </tooltip>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- Meta row (inline with subtle icons) -->
        <HBox fx:id="metaRow" alignment="CENTER_LEFT" spacing="14.0" styleClass="detail-meta-inline">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="detail-meta-item">
                    <Region styleClass="icon-region, icon-download, detail-meta-icon" />
                    <Label fx:id="pullCountLabel" styleClass="detail-meta-text" text="0" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="detail-meta-item">
                    <Region styleClass="icon-region, icon-time, detail-meta-icon" />
                    <Label fx:id="lastUpdatedLabel" styleClass="detail-meta-text" text="—" />
                </HBox>
                <HBox fx:id="parameterSizeBox" alignment="CENTER_LEFT" spacing="6.0" styleClass="detail-meta-item">
                    <Region styleClass="icon-region, icon-cube, detail-meta-icon" />
                    <Label fx:id="parameterSizeLabel" styleClass="detail-meta-text" text="-" />
                </HBox>
            </children>
        </HBox>

        <!-- Description -->
        <Label fx:id="modelDescriptionLabel" styleClass="detail-description"
               text="Description..." wrapText="true" maxWidth="Infinity" />

        <!-- Capability pills -->
        <FlowPane fx:id="badgesContainer" hgap="6.0" vgap="6.0" styleClass="detail-pill-row" />

        <Separator styleClass="apple-separator" />

        <!-- Variants section -->
        <Label fx:id="variantsHeaderLabel" styleClass="variants-header" text="0 variants" />

        <TableView fx:id="variantsTable" styleClass="variants-table">
            <columns>
                <TableColumn fx:id="colName"    text="%detail.table.name"    prefWidth="220.0" minWidth="140.0" />
                <TableColumn fx:id="colSize"    text="%detail.table.size"    prefWidth="90.0"  minWidth="70.0"  />
                <TableColumn fx:id="colContext" text="%detail.table.context" prefWidth="90.0"  minWidth="70.0"  />
                <TableColumn fx:id="colInput"   text="%detail.table.input"   prefWidth="90.0"  minWidth="70.0"  />
                <TableColumn fx:id="colAction"  text="%detail.table.action"  prefWidth="110.0" minWidth="100.0" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <!-- Pill legend: what each capability means -->
        <VBox fx:id="capabilityLegendSection" spacing="10.0" styleClass="capability-legend">
            <Label fx:id="capabilityLegendTitle" styleClass="variants-header" text="%detail.legend.title" />
            <GridPane fx:id="capabilityLegendGrid" hgap="16.0" vgap="14.0" styleClass="capability-legend-grid" />
        </VBox>
    </children>
</VBox>
